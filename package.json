{
  "name": "pretext-editor",
  "version": "0.6.3",
  "private": false,
  "description": "High-performance Canvas-virtualized text editor for large documents based @chenglou/pretext",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/molang-dev/pretext-editor.git"
  },
  "keywords": [
    "pretext",
    "code-editor",
    "syntax",
    "highlighting",
    "vscode-like"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./react/index.css": "./dist/react/index.css",
    "./vue/index.css": "./dist/vue/index.css",
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/PretextEditor.svelte"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8"
  },
  "devDependencies": {
    "@angular/core": "^22.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "svelte": "^4.2.20",
    "tm-themes": "^1.12.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2",
    "vue": "^3.5.38"
  }
}
